<Window
    x:Class="GameCheatsManager.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:GameCheatsManager.WinUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Game Cheats Manager">
    <Grid
        x:Name="RootGrid"
        Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Background="{ThemeResource LayerFillColorDefaultBrush}">
            <MenuBar
                Margin="8,0"
                Background="Transparent">
                <MenuBarItem x:Name="OptionsMenuBarItem" Title="Options">
                    <MenuFlyoutItem x:Name="SettingsMenuFlyoutItem" Text="Settings" Click="OnSettingsClick" />
                    <MenuFlyoutItem x:Name="ImportMenuFlyoutItem" Text="Import Trainers" Click="OnImportClick" />
                    <MenuFlyoutItem x:Name="OpenDownloadPathMenuFlyoutItem" Text="Open Trainer Download Path" Click="OnOpenTrainerDirectoryClick" />
                    <MenuFlyoutItem x:Name="WhitelistMenuFlyoutItem" Text="Add Paths to Whitelist" Click="OnWhitelistClick" />
                    <MenuFlyoutItem x:Name="AboutMenuFlyoutItem" Text="About" Click="OnAboutClick" />
                </MenuBarItem>
                <MenuBarItem x:Name="DataUpdateMenuBarItem" Title="Data Update">
                    <MenuFlyoutItem x:Name="UpdateTranslationsMenuFlyoutItem" Text="Update Translation Data" Click="OnUpdateTranslationsClick" />
                    <MenuFlyoutItem x:Name="UpdateSearchDataMenuFlyoutItem" Text="Update Trainer Search Data" Click="OnUpdateSearchDataClick" />
                    <MenuFlyoutItem x:Name="UpdateTrainersMenuFlyoutItem" Text="Update Trainers" Click="OnUpdateTrainersClick" />
                </MenuBarItem>
                <MenuBarItem x:Name="TrainerManagementMenuBarItem" Title="Trainer Management">
                    <MenuFlyoutItem x:Name="TrainerManagementMenuFlyoutItem" Text="Open Trainer Management" Click="OnTrainerManagementClick" />
                </MenuBarItem>
                <MenuBarItem x:Name="UploadTrainerMenuBarItem" Title="Upload Trainer">
                    <MenuFlyoutItem x:Name="UploadTrainerMenuFlyoutItem" Text="Open Upload Trainer" Click="OnUploadTrainerClick" />
                </MenuBarItem>
                <MenuBarItem x:Name="BrowseAllTrainersMenuBarItem" Title="Browse All Trainers">
                    <MenuFlyoutItem x:Name="BrowseAllTrainersMenuFlyoutItem" Text="Open Trainers Page" Click="OnBrowseAllTrainersClick" />
                </MenuBarItem>
            </MenuBar>
        </Border>

        <InfoBar
            x:Name="NotificationBar"
            Grid.Row="1"
            Margin="18,10,18,0"
            IsClosable="True"
            IsOpen="False" />

        <Grid
            Grid.Row="2"
            Margin="18,14,18,10"
            ColumnSpacing="22">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid
                Grid.Column="0"
                RowDefinitions="Auto,Auto,*,Auto">
                <TextBlock
                    x:Name="InstalledTrainersHeaderTextBlock"
                    Text="Installed Trainers"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                <Grid
                    Grid.Row="1"
                    Margin="0,10,0,0"
                    ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <FontIcon
                        VerticalAlignment="Center"
                        FontSize="32"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Glyph="&#xE721;" />
                    <TextBox
                        x:Name="InstalledSearchBox"
                        Grid.Column="1"
                        MinHeight="44"
                        PlaceholderText="Search for installed trainers"
                        TextChanged="OnInstalledSearchTextChanged" />
                </Grid>

                <Border
                    Grid.Row="2"
                    Margin="0,14,0,0"
                    Padding="2"
                    CornerRadius="8"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                    <ListView
                        x:Name="InstalledTrainersListView"
                        Background="Transparent"
                        BorderThickness="0"
                        DisplayMemberPath="DisplayName"
                        DoubleTapped="OnInstalledTrainerDoubleTapped"
                        SelectionMode="Single" />
                </Border>

                <Grid
                    Grid.Row="3"
                    Margin="0,14,0,0"
                    ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button
                        x:Name="LaunchButton"
                        Grid.Column="0"
                        MinHeight="48"
                        Content="Launch"
                        Click="OnLaunchClick" />
                    <Button
                        x:Name="DeleteButton"
                        Grid.Column="1"
                        MinHeight="48"
                        Content="Delete"
                        Click="OnDeleteClick" />
                </Grid>
            </Grid>

            <Grid
                Grid.Column="1"
                RowDefinitions="Auto,Auto,*,Auto,Auto">
                <TextBlock
                    x:Name="DownloadTrainersHeaderTextBlock"
                    Text="Download Trainers"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                <Grid
                    Grid.Row="1"
                    Margin="0,10,0,0"
                    ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <FontIcon
                        VerticalAlignment="Center"
                        FontSize="32"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Glyph="&#xE721;" />
                    <TextBox
                        x:Name="DownloadSearchBox"
                        Grid.Column="1"
                        MinHeight="44"
                        PlaceholderText="Enter keywords to download trainers"
                        KeyDown="OnDownloadSearchBoxKeyDown" />
                    <Button
                        x:Name="SearchButton"
                        Grid.Column="2"
                        MinWidth="92"
                        MinHeight="44"
                        Content="Search"
                        Click="OnSearchClick" />
                </Grid>

                <Border
                    Grid.Row="2"
                    Margin="0,14,0,0"
                    Padding="2"
                    CornerRadius="8"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                    <ListView
                        x:Name="DownloadResultsListView"
                        Background="Transparent"
                        BorderThickness="0"
                        DisplayMemberPath="DisplayName"
                        DoubleTapped="OnDownloadResultDoubleTapped"
                        SelectionMode="Single" />
                </Border>

                <StackPanel
                    Grid.Row="3"
                    Margin="0,14,0,0"
                    Spacing="4">
                    <TextBlock
                        x:Name="ActiveOperationTextBlock"
                        Text="Idle"
                        FontSize="13"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock
                        x:Name="DownloadProgressTextBlock"
                        FontSize="12"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <ProgressBar
                        x:Name="DownloadProgressBar"
                        Height="6"
                        Minimum="0"
                        Maximum="100"
                        Visibility="Collapsed" />
                </StackPanel>

                <StackPanel
                    Grid.Row="4"
                    Margin="0,14,0,0"
                    Spacing="6">
                    <TextBlock
                        x:Name="DownloadPathLabelTextBlock"
                        Text="Trainer download path:"
                        FontSize="13"
                        FontWeight="SemiBold" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBox
                            x:Name="DownloadPathTextBox"
                            IsReadOnly="True"
                            MinHeight="44" />
                        <Button
                            x:Name="BrowseButton"
                            Grid.Column="1"
                            MinWidth="48"
                            MinHeight="44"
                            Content="..."
                            Click="OnChangePathClick"
                            ToolTipService.ToolTip="Browse" />
                    </Grid>
                </StackPanel>
            </Grid>
        </Grid>

        <Expander
            Grid.Row="3"
            Margin="18,0,18,16"
            IsExpanded="False">
            <Expander.Header>
                <TextBlock
                    x:Name="ActivityHeaderTextBlock"
                    Text="Activity"
                    FontWeight="SemiBold" />
            </Expander.Header>
            <ScrollViewer
                Margin="0,8,0,0"
                MaxHeight="120">
                <StackPanel
                    x:Name="StatusPanel"
                    Spacing="4" />
            </ScrollViewer>
        </Expander>
    </Grid>
</Window>
